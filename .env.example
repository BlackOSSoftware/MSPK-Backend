PORT=4000
NODE_ENV=production
FRONTEND_URL=https://your-frontend-domain.com

MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>/<db>?retryWrites=true&w=majority
JWT_SECRET=change_this_to_long_random_secret
JWT_EXPIRES_IN=10d
ENCRYPTION_KEY=12345678901234567890123456789012
LOG_LEVEL=info

# Market-data bridge (backend -> market-data VPS websocket)
MARKET_DATA_WS_URL=wss://market.yourdomain.com/ws/market
MARKET_DATA_API_KEY=replace_with_market_data_api_key
MARKET_DATA_INTERVAL_MS=300
MARKET_DATA_BOOT_SYMBOLS=EURUSD,BTCUSD,XAUUSD
MARKETDATA_STATS_INTERVAL_MS=5000
DISABLE_LIVE_FEED=false

# Optional backward compatibility aliases
MT5_WS_URL=
MT5_WS_API_KEY=
MT5_WS_INTERVAL_MS=

# Market/Broker credentials (optional if feature not used)
KITE_API_KEY=
KITE_API_SECRET=
KITE_ACCESS_TOKEN=
FMP_API_KEY=
USE_MOCK_BROKER=true

FYERS_APP_ID=
FYERS_SECRET_ID=
FYERS_REDIRECT_URI=

# WhatsApp (optional)
WHATSAPP_PROVIDER=ultramsg
WHATSAPP_DEFAULT_COUNTRY_CODE=91

# UltraMsg (recommended WhatsApp provider)
ULTRAMSG_BASE_URL=https://api.ultramsg.com
ULTRAMSG_INSTANCE_ID=
ULTRAMSG_TOKEN=
ULTRAMSG_PRIORITY=10
ULTRAMSG_DEFAULT_COUNTRY_CODE=91

# Meta WhatsApp Cloud API (optional alternate provider)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# MSG91 (optional)
MSG91_AUTH_KEY=
MSG91_OTP_TEMPLATE_ID=
MSG91_SMS_FLOW_ID=
MSG91_WHATSAPP_INTEGRATED_NUMBER=
MSG91_WELCOME_TEMPLATE_ID=
MSG91_EMAIL_DOMAIN=
MSG91_FROM_EMAIL=
MSG91_EMAIL_TEMPLATE_ID=

# Telegram (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHANNEL_ID=

# Redis (recommended in production)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Optional SMTP
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
